{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https:; media-src 'self' blob: data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https:; frame-src https://www.youtube.com https://youtube.com; form-action 'self'; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/classes.php",
      "destination": "/api/classes"
    },
    {
      "source": "/api/members.php",
      "destination": "/api/members"
    },
    {
      "source": "/api/support.php",
      "destination": "/api/support"
    },
    {
      "source": "/api/submissions.php",
      "destination": "/api/submissions"
    },
    {
      "source": "/api/settings.php",
      "destination": "/api/classes?resource=settings"
    },
    {
      "source": "/api/backup.php",
      "destination": "/api/classes?resource=backup"
    },
    {
      "source": "/api/settings",
      "destination": "/api/classes?resource=settings"
    },
    {
      "source": "/api/backup",
      "destination": "/api/classes?resource=backup"
    },
    {
      "source": "/api/progress.php",
      "destination": "/api/progress"
    },
    {
      "source": "/api/login.php",
      "destination": "/api/login"
    },
    {
      "source": "/api/logout.php",
      "destination": "/api/logout"
    },
    {
      "source": "/api/profile.php",
      "destination": "/api/profile"
    },
    {
      "source": "/api/upload-file.php",
      "destination": "/api/upload-file"
    },
    {
      "source": "/api/upload-video.php",
      "destination": "/api/upload-video"
    },
    {
      "source": "/api/video.php",
      "destination": "/api/video"
    },
    {
      "source": "/api/lynk-webhook.php",
      "destination": "/api/lynk-webhook"
    },
    {
      "source": "/api/tripay-checkout.php",
      "destination": "/api/tripay-checkout"
    },
    {
      "source": "/api/tripay-webhook.php",
      "destination": "/api/tripay-webhook"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
